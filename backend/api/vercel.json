{
  "version": 2,
  "functions": {
    "api/claude.ts": { "maxDuration": 30 },
    "api/routes.ts": { "maxDuration": 15 },
    "api/health.ts": { "maxDuration": 10 }
  },
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["../../packages/shared/src/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/claude",
      "methods": ["POST"],
      "dest": "/api/claude.ts",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    {
      "src": "/api/routes/popular",
      "methods": ["GET"],
      "dest": "/api/routes.ts",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/api/health",
      "methods": ["GET"],
      "dest": "/api/health.ts"
    },
    {
      "src": "/api/(.*)",
      "methods": ["OPTIONS"],
      "dest": "/api/health.ts",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    }
  ]
}
