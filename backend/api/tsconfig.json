{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@touring/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["api/**/*.ts", "../../packages/shared/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
